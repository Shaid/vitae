---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import EmploymentPanel from "@/components/EmploymentPanel.astro";
import EducationPanel from "@/components/EducationPanel.astro";
import SkillsPanel from "@/components/SkillsPanel.astro";
import { getResumeData, getAvailableClients } from "@/lib/data";

export function getStaticPaths() {
  const clients = getAvailableClients();
  return clients.map((client) => ({ params: { client } }));
}

const { client } = Astro.params;
const resume = getResumeData(client!);

if (!resume) {
  return Astro.redirect("/404");
}
---

<BaseLayout title={`${resume.name} | Resume`}>
  <main class="max-w-6xl mx-auto px-4 py-8 grid grid-cols-1 md:grid-cols-[300px_1fr] gap-8">
    <Header resume={resume} />
    <div>
      <EmploymentPanel data={resume.employment} />
      <EducationPanel data={resume.education} />
      <SkillsPanel data={resume.skills} />
    </div>
  </main>
</BaseLayout>
